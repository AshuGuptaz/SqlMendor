# Copy to .env and adjust. Sensible dev defaults are baked in, so .env is optional.

# --- Auth (demo) ---
JWT_SECRET=dev-secret-change-me
DEMO_USERNAME=demo
DEMO_PASSWORD=demo-password

# --- Groq LLM (recommended — much better accuracy than heuristic baseline) ---
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Model (Apple Silicon / MLX) ---
# BASE_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
# ADAPTER_PATH=adapters/sql-lora

# --- Agent ---
# MAX_REPAIR_ATTEMPTS=3
# FEW_SHOT_K=3
